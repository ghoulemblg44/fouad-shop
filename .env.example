MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority
PORT=5000
NODE_ENV=development

# CORS: set to your real frontend origin in production, e.g. https://fouadshop.com
CLIENT_URL=*

# JWT auth - generate your own with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Used only once by `npm run seed:admin` to create the first admin account.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!

# ---------------------------------------------------------------------------
# CLOUDINARY (image hosting) - free tier at https://cloudinary.com/users/register/free
# Without these, uploads fall back to local disk, which is WIPED on every
# Render redeploy. Set these before going to production.
# Find them on your Cloudinary Dashboard home page after signup.
# ---------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

